# ─────────────────────────────────────────────────────────────
#  Dark Fashion Store — variáveis de ambiente
#  Copie para .env (local) ou cadastre no Dokploy (deploy).
#
#  RUNTIME  = lidas pelo servidor em produção (cadastrar em Environment)
#  BUILD    = "assadas" no bundle do front pelo Vite; no Dokploy precisam
#             ir como BUILD ARGS (Build > Build Args), não só em Environment.
# ─────────────────────────────────────────────────────────────

# ── Núcleo (RUNTIME, obrigatórias) ───────────────────────────
NODE_ENV=production
PORT=3000
# MySQL. No Dokploy, crie um banco MySQL e use o host interno da rede dele.
# Ex.: mysql://usuario:senha@vanta-mysql:3306/vanta
DATABASE_URL=mysql://user:password@localhost:3306/vanta
# Segredo p/ assinar os cookies de sessão (JWT). Gere com: openssl rand -hex 32
JWT_SECRET=troque-por-uma-string-aleatoria-longa

# ── URLs públicas da app (BUILD + RUNTIME) ───────────────────
# Domínio final servido pelo Dokploy/Traefik (com https).
VITE_APP_URL=https://loja.seudominio.com.br
VITE_FRONTEND_URL=https://loja.seudominio.com.br
# Identificador da app (origem Manus). Pode manter o atual ou um slug seu.
VITE_APP_ID=dark-fashion-store

# ── Pagamento Pix (RUNTIME) — self-contained, sem dependência externa ──
PIX_KEY=sua-chave-pix
PIX_OWNER_NAME=NOME DO RECEBEDOR

# ── E-mail transacional via SMTP (RUNTIME, opcional) ─────────
# Qualquer SMTP (seu próprio, ou um provedor). Em branco = e-mail desativado.
SMTP_HOST=
SMTP_PORT=587
SMTP_SECURE=false          # true p/ porta 465 (TLS implícito); 587 usa STARTTLS
SMTP_USER=
SMTP_PASSWORD=

# ── Login / OAuth (Manus — resolver "depois") ────────────────
# Hoje o login chama o servidor de auth do Manus. Enquanto não migramos
# p/ auth próprio, preencha com os valores do Manus p/ o login funcionar;
# deixe vazio se for subir sem login por enquanto.
OAUTH_SERVER_URL=
OWNER_OPEN_ID=
VITE_OAUTH_PORTAL_URL=     # (BUILD) portal de login do front

# ── Stripe (RUNTIME + BUILD, opcional) ───────────────────────
# Só se for usar cartão via Stripe além do Pix.
STRIPE_SECRET_KEY=
VITE_STRIPE_PUBLISHABLE_KEY=

# ── Forge / Manus (opcional) ─────────────────────────────────
# Só necessárias se ligar geração de imagem por IA, voz, mapas etc.
# (não usado pelo e-commerce básico; imagens de produto são URLs no banco).
BUILT_IN_FORGE_API_URL=
BUILT_IN_FORGE_API_KEY=
VITE_FRONTEND_FORGE_API_URL=     # (BUILD)
VITE_FRONTEND_FORGE_API_KEY=     # (BUILD)
